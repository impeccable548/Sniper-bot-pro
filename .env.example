# ── Wallet ────────────────────────────────────────────────────────────────────
# Your Solana wallet private key (base58 — from Phantom → Settings → Export Private Key)
PRIVATE_KEY=your_private_key_here

# ── RPC ───────────────────────────────────────────────────────────────────────
# Free public node (slow) or paid for speed:
#   Helius:    https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#   QuickNode: https://your-endpoint.quiknode.pro/YOUR_KEY
#   Shyft:     https://rpc.shyft.to?api_key=YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

# ── Jito ─────────────────────────────────────────────────────────────────────
# Optional — for bundle submission (skip public mempool)
# Default: https://mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot to get your numeric Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Full-Auto defaults ────────────────────────────────────────────────────────
AUTO_BUY_SOL=0.05
AUTO_TP=75
AUTO_SL=15
AUTO_TS=20
